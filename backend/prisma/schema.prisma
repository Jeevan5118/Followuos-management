generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String     @id @default(uuid())
  email                  String     @unique
  password               String
  name                   String?
  role                   String     @default("USER")
  hasCompletedOnboarding Boolean    @default(false)
  followUps              FollowUp[]
}

model City {
  id            String          @id @default(uuid())
  name          String          @unique
  createdAt     DateTime        @default(now())
  colleges      College[]
  members       Member[]
  coordinators  Coordinator[]
  followUps     FollowUp[]
  reminders     Reminder[]
  collegeDrives CollegeDrive[]
}

model College {
  id           String          @id @default(uuid())
  name         String
  category     String
  createdAt    DateTime        @default(now())
  cityId       String?
  city         City?           @relation(fields: [cityId], references: [id], onDelete: Cascade)
  members      CollegeMember[]
  coordinators Coordinator[]
  followUps    FollowUp[]
  reminders    Reminder[]
  collegeDrives CollegeDrive[]
}

model Member {
  id       String          @id @default(uuid())
  name     String
  email    String?
  cityId   String?
  city     City?           @relation(fields: [cityId], references: [id], onDelete: Cascade)
  colleges CollegeMember[]
}

model CollegeMember {
  collegeId String
  memberId  String
  college   College @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  member    Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@id([collegeId, memberId])
}

model Coordinator {
  id          String  @id @default(uuid())
  name        String
  phoneNumber String
  collegeId   String
  college     College @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  cityId      String?
  city        City?   @relation(fields: [cityId], references: [id], onDelete: Cascade)
}

model FollowUp {
  id               String    @id @default(uuid())
  status           String    @default("No Status Change")
  description      String
  contactName      String?
  nextFollowupDate DateTime?
  createdAt        DateTime  @default(now())
  createdById      String
  createdBy        User      @relation(fields: [createdById], references: [id])
  collegeId        String
  college          College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  cityId           String?
  city             City?     @relation(fields: [cityId], references: [id], onDelete: Cascade)
}

model Reminder {
  id               String    @id @default(uuid())
  title            String
  description      String?
  dueDate          DateTime
  createdAt        DateTime  @default(now())
  collegeId        String
  college          College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  cityId           String?
  city             City?     @relation(fields: [cityId], references: [id], onDelete: Cascade)
}

model CollegeDrive {
  id          String   @id @default(uuid())
  date        DateTime
  description String?
  createdAt   DateTime @default(now())
  collegeId   String
  college     College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  cityId      String?
  city        City?    @relation(fields: [cityId], references: [id], onDelete: Cascade)
}

{
    "name": "followups-management",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "frontend",
        "backend"
    ],
    "scripts": {
        "dev:frontend": "cd frontend && npm run dev",
        "dev:backend": "nodemon backend/src/index.ts",
        "build": "cd frontend && npm install && npm run build",
        "postinstall": "prisma generate --schema=backend/prisma/schema.prisma",
        "prisma:generate": "prisma generate --schema=backend/prisma/schema.prisma"
    },
    "dependencies": {
        "@neondatabase/serverless": "^1.1.0",
        "@prisma/adapter-neon": "^7.8.0",
        "@prisma/adapter-pg": "7.7.0",
        "@prisma/client": "7.7.0",
        "@prisma/config": "7.7.0",
        "@types/axios": "^0.9.36",
        "axios": "^1.15.2",
        "bcryptjs": "^3.0.3",
        "cors": "^2.8.6",
        "dotenv": "^17.4.0",
        "express": "^5.2.1",
        "jsonwebtoken": "^9.0.3",
        "pg": "^8.20.0",
        "ws": "^8.20.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^24.12.0",
        "@types/pg": "^8.20.0",
        "@types/ws": "^8.18.1",
        "nodemon": "^3.1.14",
        "prisma": "7.7.0",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.2"
    }
}
